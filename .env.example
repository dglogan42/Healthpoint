# Google Maps JavaScript API key (required for map display)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Healthpoint FHIR API (optional — app uses demo data without this)
# Register at https://www.healthpointapi.com/get-started
HEALTHPOINT_API_KEY=your_healthpoint_api_key
HEALTHPOINT_BASE_URL=https://uat.healthpointapi.com/baseR4/

# Google Geocoding API key for address search (optional, uses same key as maps)
GOOGLE_GEOCODING_API_KEY=your_google_maps_api_key

# Gemini API for voice search natural language parsing (optional)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# Server port
PORT=3002